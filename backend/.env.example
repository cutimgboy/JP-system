# 数据库配置
DB_HOST=127.0.0.1
DB_PORT=3306
DB_USER=jp_user
DB_PASSWD=change_me
DB_DATABASE=jp_system
DB_SYNCHRONIZE=false

# 运行环境
NODE_ENV=development
PORT=3000

# 安全配置
JWT_SECRET=change_this_to_a_random_secret_with_at_least_32_chars
JWT_EXPIRES_IN=7d
CORS_ORIGINS=http://localhost:5173,http://localhost:5176
ENABLE_SWAGGER=false
EXPOSE_VERIFICATION_CODE=false
ENABLE_FIXED_SMS_CODE=true
FIXED_SMS_CODE=123456

# OAuth 配置
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=
GOOGLE_CALLBACK_URL=http://localhost:3000/auth/google/callback
FACEBOOK_APP_ID=
FACEBOOK_APP_SECRET=
FACEBOOK_CALLBACK_URL=http://localhost:3000/auth/facebook/callback

# Redis 配置
REDIS_HOST=localhost
REDIS_PORT=6379
REDIS_PASSWORD=
REDIS_DB=0

# 行情源配置
QUOTE_WS_TOKEN=
MOCK_QUOTE_DATA=true
DISABLE_QUOTE_INIT=false

# 行情缓存配置
STOCK_QUOTE_CACHE_TTL=60
ALL_QUOTES_CACHE_TTL=2
SPREAD_CACHE_TTL=300
PRICE_DETECTION_THRESHOLD=0.0001
