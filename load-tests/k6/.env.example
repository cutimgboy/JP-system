BASE_URL=http://8.134.77.172
API_PREFIX=/api

# 可选：公开行情压测使用的产品代码，必须是后端 Product.code。
PRODUCT_CODES=BTC,ETH,AAPL,NVDA,TSLA

# smoke | baseline | ramp | stress
SCENARIO=baseline

# 阈值：失败率、P95 响应时间、check 通过率。
MAX_FAILED_RATE=0.01
MAX_P95_MS=1000
MIN_CHECK_RATE=0.99

# 模拟用户思考时间，单位秒。
THINK_TIME_MIN=1
THINK_TIME_MAX=3

# 登录后接口压测二选一：
# 1. 直接填一个测试用户 token。
AUTH_TOKEN=

# 2. 或者填测试手机号和密码，让脚本 setup 阶段自动登录。
TEST_PHONE=
TEST_PASSWORD=

# trading-demo.js 会创建模拟账户订单，谨慎压写接口。
INVESTMENT_AMOUNT=100000
TRADE_DURATION_SECONDS=15
